# Copy to `.env.local` and fill in. If VITE_SUPABASE_URL is empty, the app runs against a
# localStorage-backed repository so you can develop without provisioning Supabase.
#
# Browser-safe: only the ANON key belongs here. NEVER put the service-role key in any
# VITE_* variable — it would ship to the browser. Service role is used only for running
# migrations / seeding / bucket creation from a trusted environment (see docs/SETUP.md).

VITE_SUPABASE_URL=https://snowiacdagibrxwhkzoi.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNub3dpYWNkYWdpYnJ4d2hrem9pIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk4NDQ2MDUsImV4cCI6MjA5NTQyMDYwNX0.3luh1IO9m3WilVaiZpXg0W0lu5AGYzvIXcPEj-mEh1E

# Optional: the storage bucket name for chapter images.
VITE_SUPABASE_IMAGE_BUCKET=chapter-images
